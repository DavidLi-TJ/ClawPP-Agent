* {
    font-family: "-apple-system", "Segoe UI Variable Text", "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    color: #000000;
}

QMainWindow,
QWidget#mainWindowRoot {
    background: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #ECF0F6, stop: 0.5 #F3F5FA, stop: 1 #FAFBFC);
}

QSplitter#mainSplitter {
    background: transparent;
}

QSplitter#mainSplitter::handle {
    background: rgba(148, 163, 184, 0.10);
    border-radius: 999px;
}

QSplitter#mainSplitter::handle:hover {
    background: rgba(0, 122, 255, 0.16);
}

QWidget#sidebarShell {
    background: rgba(248, 250, 253, 0.62);
    border-right: 1px solid rgba(148, 163, 184, 0.12);
}

QWidget#chatSurfacePanel {
    background: transparent;
}

QWidget#topBar {
    background: rgba(255, 255, 255, 0.56);
    border-bottom: 1px solid rgba(148, 163, 184, 0.10);
}

QFrame#sidebarHeroCard,
QFrame#sidebarNavSection,
QFrame#sidebarConfigSection,
QFrame#sidebarControlCard,
QFrame#sidebarFooter,
QFrame#sessionPanelCard,
QFrame#contentHeader,
QFrame#contentBody,
QFrame#chatAreaPanel,
QWidget#chatInputContainer,
QGroupBox,
QWidget#settingsTabWidget,
QWidget#workspaceStack,
QWidget#chatViewRoot,
QWidget#logViewRoot {
    background: rgba(255, 255, 255, 0.62);
    border: 1px solid rgba(139, 139, 144, 0.14);
    border-radius: 22px;
}

QFrame#contentBody,
QFrame#chatAreaPanel,
QWidget#workspaceStack,
QWidget#chatViewRoot,
QWidget#logViewRoot {
    border-radius: 24px;
}

QFrame#contentHeader {
    background: rgba(255, 255, 255, 0.58);
}

QLabel#sidebarAppTitle,
QLabel#contentTitleLabel {
    font-size: 28px;
    font-weight: 700;
    color: #000000;
}

QLabel#sidebarAppSubtitle,
QLabel#sidebarHeroHint,
QLabel#contentSubtitleLabel,
QLabel#sidebarMultiAgentHint,
QLabel#sidebarBackendLabel,
QLabel#sidebarVersionLabel {
    color: rgba(60, 60, 67, 0.60);
    font-size: 12px;
}

QLabel#sidebarSectionLabel,
QLabel#contentSectionLabel {
    color: #007AFF;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
}

QLabel#sidebarTokenLabel,
QLabel#connectionStatusLabel {
    background: rgba(241, 245, 249, 0.86);
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 999px;
    padding: 8px 14px;
    color: #475569;
    font-size: 12px;
    font-weight: 600;
}

QLabel#connectionStatusLabel[connected="true"] {
    background: rgba(220, 252, 231, 0.94);
    border-color: rgba(52, 199, 89, 0.26);
    color: #166534;
}

QLabel#connectionStatusLabel[connected="false"] {
    background: rgba(241, 245, 249, 0.90);
    border-color: rgba(148, 163, 184, 0.16);
    color: #64748B;
}

QPushButton {
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 14px;
    padding: 10px 16px;
    color: #000000;
    font-size: 13px;
    font-weight: 600;
}

QPushButton:hover {
    background: rgba(248, 250, 252, 0.90);
    border-color: rgba(0, 122, 255, 0.26);
}

QPushButton:pressed {
    background: rgba(226, 232, 240, 0.86);
}

QPushButton#primaryActionButton,
QPushButton#chatSendButton {
    background: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #007AFF, stop: 1 #5856D6);
    color: #FFFFFF;
    border: none;
    border-radius: 18px;
}

QPushButton#chatTestApiButton {
    background: rgba(14, 165, 233, 0.90);
    color: #FFFFFF;
    border: 1px solid rgba(2, 132, 199, 0.92);
    border-radius: 12px;
    font-weight: 700;
}

QPushButton#sidebarNavButton,
QPushButton#sidebarConfigItem,
QPushButton#contentRefreshBtn,
QPushButton#logRefreshButton,
QPushButton#logClearButton,
QPushButton#logAutoRefreshButton,
QPushButton#logViewRoot QPushButton {
    text-align: left;
    padding: 10px 14px;
}

QPushButton#primaryActionButton:hover,
QPushButton#chatSendButton:hover {
    background: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #0070E0, stop: 1 #005ED4);
}

QPushButton#sidebarNavButton {
    border-radius: 16px;
    padding: 11px 14px;
    text-align: left;
}

QPushButton#sidebarNavButton:checked {
    background: rgba(219, 234, 254, 0.94);
    border-color: rgba(0, 122, 255, 0.38);
    color: #0070E0;
}

QPushButton#sidebarConfigItem {
    border-radius: 16px;
    background: rgba(248, 250, 252, 0.94);
}

QPushButton#contentRefreshBtn,
QPushButton#logRefreshButton,
QPushButton#logClearButton,
QPushButton#logAutoRefreshButton {
    border-radius: 16px;
}

QPushButton#settingsActionButton,
QPushButton#sidebarSettingsButton,
QPushButton#sessionNewButton,
QPushButton#sessionSecondaryButton,
QPushButton#chatStopButton {
    background: rgba(255, 255, 255, 0.74);
}

QPushButton#sidebarTabButton {
    text-align: left;
    padding: 11px 14px;
    border-radius: 14px;
}

QPushButton#sidebarTabButton:checked {
    background: rgba(219, 234, 254, 0.88);
    border-color: rgba(0, 122, 255, 0.36);
    color: #0070E0;
}

QPushButton#sidebarSettingsButton {
    text-align: left;
    padding: 12px 14px;
    font-weight: 700;
}

QToolButton,
QPushButton#toolbarIconButton,
QToolButton#toolbarIconButton {
    background: transparent;
    border: none;
    border-radius: 14px;
}

QToolButton:hover,
QPushButton#toolbarIconButton:hover {
    background: rgba(229, 231, 235, 0.78);
}

QToolButton:pressed,
QPushButton#toolbarIconButton:pressed {
    background: rgba(209, 213, 219, 0.88);
}

QToolButton#windowControlButton,
QToolButton#windowCloseButton {
    background: transparent;
    border-radius: 12px;
    font-size: 15px;
}

QToolButton#windowCloseButton:hover {
    background: rgba(255, 59, 48, 0.14);
    color: #B91C1C;
}

QComboBox {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(134, 151, 176, 0.18);
    border-radius: 14px;
    padding: 6px 12px;
    min-height: 22px;
}

QComboBox:hover {
    border-color: rgba(0, 122, 255, 0.32);
}

QComboBox::drop-down {
    border: none;
    width: 22px;
    border-top-right-radius: 14px;
    border-bottom-right-radius: 14px;
}

QComboBox QAbstractItemView {
    border: 1px solid rgba(134, 151, 176, 0.18);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.96);
    selection-background-color: rgba(219, 234, 254, 0.93);
    selection-color: #0070E0;
    outline: none;
    padding: 4px;
}

QComboBox QAbstractItemView::item {
    border-radius: 10px;
    padding: 6px 10px;
    min-height: 28px;
}

QMenu {
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(160, 195, 240, 0.22);
    border-radius: 14px;
    padding: 6px;
}

QMenu::item {
    border-radius: 10px;
    padding: 8px 28px 8px 14px;
    margin: 2px 4px;
}

QMenu::item:selected {
    background: rgba(0, 122, 255, 0.10);
    color: #0070E0;
}

QMenu::separator {
    height: 1px;
    background: rgba(148, 163, 184, 0.16);
    margin: 4px 10px;
}

QLineEdit, QTextEdit, QPlainTextEdit {
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 14px;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.78);
    selection-background-color: rgba(0, 122, 255, 0.20);
    selection-color: #111827;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border-color: rgba(0, 122, 255, 0.38);
}

QDialog {
    background: #F4F7FC;
    border-radius: 14px;
}

QSpinBox, QDoubleSpinBox {
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 14px;
    padding: 6px 10px;
    min-height: 22px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: rgba(0, 122, 255, 0.38);
}

QPlainTextEdit#chatInputEdit {
    background: transparent;
    border: none;
    padding: 14px 12px 12px 12px;
    font-size: 14px;
    color: #000000;
    caret-color: #000000;
    selection-background-color: rgba(0, 122, 255, 0.24);
    selection-color: #111827;
}

QWidget#chatInputContainer {
    margin-top: 8px;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 24px;
}

QLabel#chatHintLabel {
    color: rgba(60, 60, 67, 0.60);
    font-size: 12px;
}

QFrame#assistantMessageBubble {
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 22px;
    margin: 6px 12px;
}

QFrame#userMessageBubble {
    background: rgba(0, 122, 255, 0.92);
    border: 1px solid rgba(0, 102, 204, 0.16);
    border-radius: 22px;
    margin: 6px 12px;
}

QLabel#messageAvatarLabel {
    min-width: 36px;
    max-width: 36px;
    min-height: 36px;
    max-height: 36px;
    border-radius: 18px;
    font-size: 12px;
    font-weight: 700;
    color: #FFFFFF;
    background: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #007AFF, stop: 1 #5856D6);
}

QLabel#messageAvatarLabel[role="user"] {
    background: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #34C759, stop: 1 #30D158);
}

QLabel#messageAvatarLabel[role="assistant"] {
    background: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #007AFF, stop: 1 #5856D6);
}

QTextBrowser#messageContentView {
    background: transparent;
    border: none;
    color: #1D1D1F;
    font-size: 14px;
}

QWidget#loadingIndicator {
    background: transparent;
}

QLabel#loadingIndicatorText {
    color: #475467;
    font-size: 12px;
    font-weight: 600;
}

QLabel#loadingIndicatorSpinner {
    color: #007AFF;
    font-size: 16px;
    font-weight: 700;
}

QStackedWidget#workspaceStack {
    background: transparent;
    border: none;
}

QWidget#chatViewRoot {
    background: transparent;
    border: none;
}

QScrollArea#chatScrollArea {
    background: transparent;
    border: none;
}

QWidget#chatMessageContainer {
    background: transparent;
}

QWidget#chatInputContainer {
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 24px;
}

QTableWidget#logTable {
    background: transparent;
    border: none;
    gridline-color: rgba(148, 163, 184, 0.14);
    selection-background-color: rgba(219, 234, 254, 0.86);
    selection-color: #0070E0;
}

QTableWidget#logTable::item {
    padding: 10px 12px;
}

QHeaderView::section {
    background: rgba(248, 250, 252, 0.94);
    border: none;
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    padding: 10px 12px;
    font-weight: 700;
    color: #334155;
}

QWidget#logViewRoot QLineEdit,
QWidget#logViewRoot QComboBox,
QWidget#logViewRoot QPushButton {
    min-height: 34px;
}

QWidget#logViewRoot QLineEdit,
QWidget#logViewRoot QComboBox {
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 14px;
    padding: 6px 12px;
}

QWidget#logViewRoot QPushButton {
    background: rgba(255, 255, 255, 0.70);
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 14px;
}

QListWidget#sessionList {
    background: transparent;
    border: none;
    outline: none;
}

QListWidget#sessionList::item {
    margin: 3px 4px;
    padding: 10px 12px;
    border-radius: 14px;
    color: #000000;
}

QListWidget#sessionList::item:hover {
    background: rgba(229, 231, 235, 0.68);
}

QListWidget#sessionList::item:selected {
    background: rgba(219, 234, 254, 0.93);
    color: #007AFF;
    font-weight: 700;
}

QListWidget#sessionList::item:selected:hover {
    background: rgba(191, 219, 254, 0.96);
}

QScrollArea {
    background: transparent;
    border: none;
}

QScrollArea > QWidget > QWidget {
    background: transparent;
}

QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: rgba(148, 163, 184, 0.72);
    min-height: 30px;
    border-radius: 5px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(100, 116, 139, 0.88);
}

QScrollBar::handle:vertical:pressed {
    background: rgba(71, 85, 105, 0.93);
}

QScrollBar::sub-line:vertical,
QScrollBar::add-line:vertical,
QScrollBar::up-arrow:vertical,
QScrollBar::down-arrow:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical,
QScrollBar::sub-line:horizontal,
QScrollBar::add-line:horizontal,
QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
    width: 0;
    height: 0;
}

QScrollBar:horizontal {
    background: transparent;
    height: 10px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background: rgba(148, 163, 184, 0.72);
    min-width: 30px;
    border-radius: 5px;
    margin: 2px;
}

QDialog {
    background: #F7F9FC;
}

QGroupBox {
    margin-top: 12px;
    padding-top: 12px;
    font-weight: 700;
}

QTabWidget::pane {
    border: none;
}

QTabBar::tab {
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(134, 151, 176, 0.16);
    border-bottom: none;
    padding: 8px 14px;
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
    margin-right: 4px;
}

QTabBar::tab:selected {
    background: rgba(219, 234, 254, 0.93);
    color: #0070E0;
}